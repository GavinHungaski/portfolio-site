---
import AboutLayout from "../layouts/AboutLayout.astro";
import { SOCIAL_LINKS } from "../consts";
import { Image } from "astro:assets";
import graduationPic from "../assets/graduation_pic.jpg";
---

<AboutLayout
  title="About Me"
  description="CS grad on a deliberate path toward Robotics & ML engineering. Here's where I'm coming from and where I'm headed."
>
  <!-- Intro -->
  <section class="mb-10">
    <p class="text-lg leading-[1.75]">
      Hey — I'm <strong>Gavin Hungaski</strong>, a recent computer science
      graduate based in the US. I got my start building full-stack web
      applications, but my real goal is to work in
      <strong>Robotics and Machine Learning engineering</strong>.
    </p>
    <p class="text-lg leading-[1.75]">
      Rather than jumping into a course and calling it done, I'm taking a
      project-based approach: build real things, understand them deeply, write
      about what I learn, and document the whole journey publicly. This site is
      that record.
    </p>
  </section>

  <!-- Education -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      My Education
    </h2>
    <div class="flex flex-row items-center gap-4 max-sm:flex-col max-sm:items-start">
      <Image
        src={graduationPic}
        alt="Gavin Hungaski at graduation"
        class="w-full max-w-[360px] rounded-xl shadow-[0_4px_16px_rgba(0,0,0,0.12)] object-cover"
      />
      <p>
        I graduated from Kutztown University of Pennsylvania with a B.S. in
        Computer Science in December, 2025.
      </p>
    </div>
  </section>

  <!-- Where I'm headed -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      Where I'm headed
    </h2>
    <p>
      My path runs through systems programming (C++, memory management, data
      structures from scratch), then into ML fundamentals (Autograd engine, CNN
      from scratch and a particle filter) then into ROS 2 and real robotics
      middleware (fundamentals bot, lidar, and vision pipeline among others).
      Each project is a deliberate step in that direction — not a checkbox, but
      a real artifact I can point to and explain.
    </p>
  </section>

  <!-- Certifications -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      Certifications
    </h2>
    <ul class="list-none p-0 m-0 flex flex-col gap-3">
      <li
        class="flex items-center gap-3 px-4 py-3 bg-[var(--surface)] border border-[var(--border)] rounded-lg text-[0.95rem]"
      >
        <span class="text-lg">✅</span>
        <div>
          <strong>Full Stack Web Development</strong>
          <a
            class="text-[rgb(var(--gray))] no-underline hover:text-[var(--accent)]"
            href="https://www.udemy.com/certificate/UC-d7449106-81ad-4113-8736-0a6b60622995/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span> — Udemy</span>
          </a>
        </div>
      </li>
    </ul>
  </section>

  <!-- Current Focus -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      Current Focus
    </h2>
    <ul class="list-none p-0 m-0 flex flex-col gap-2 text-[0.95rem] leading-relaxed">
      <li>
        🔧 <strong>C++ fundamentals</strong> — getting back up to speed with modern
        C++
      </li>
      <li>
        🧠 <strong>Systems programming</strong> — memory allocators, data structures
        from scratch
      </li>
      <li>📡 <strong>Robotics & ML</strong> — next on the roadmap</li>
    </ul>
  </section>

  <!-- Skills & Tools -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      Skills &amp; Tools
    </h2>
    <div class="flex flex-col gap-5">
      <!-- Currently learning -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest text-[rgb(var(--gray))] mb-2"
        >
          Currently learning
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {
            ["Intermediate C++", "Systems Programming", "Memory Management"].map((tag) => (
              <span class="text-xs bg-[rgb(var(--gray-light))] text-[rgb(var(--gray-dark))] px-2.5 py-1 rounded font-mono">
                {tag}
              </span>
            ))
          }
        </div>
      </div>

      <!-- Web background -->
      <div>
        <h3
          class="text-xs font-bold uppercase tracking-widest text-[rgb(var(--gray))] mb-2"
        >
          Web background
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {
            [
              "TypeScript",
              "JavaScript",
              "React",
              "Node.js",
              "Astro",
              "TailwindCSS",
              "PostGreSQL",
            ].map((tag) => (
              <span class="text-xs bg-[rgb(var(--gray-light))] text-[rgb(var(--gray-dark))] px-2.5 py-1 rounded font-mono">
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Get in touch -->
  <section class="mt-10">
    <h2 class="text-[1.4rem] font-bold mb-3 text-[rgb(var(--black))]">
      Get in touch
    </h2>
    <p>
      Find me on <a
        href={SOCIAL_LINKS.github}
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      or connect on <a
        href={SOCIAL_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer">LinkedIn</a
      >. I'm always open to talking about systems programming, robotics, or
      anything in between.
    </p>
    <a
      href="/Resume.pdf"
      download="Gavin_Hungaski_Resume.pdf"
      class="inline-block px-5 py-2 rounded-md text-sm font-semibold no-underline bg-transparent text-[var(--accent)] border-2 border-[var(--border)] transition-all duration-150 hover:border-[var(--accent)] hover:bg-[var(--surface-2)]"
    >
      ↓ Download Resume
    </a>
  </section>
</AboutLayout>
