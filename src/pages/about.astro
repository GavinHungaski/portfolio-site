---
import AboutLayout from "../layouts/AboutLayout.astro";
import { SOCIAL_LINKS } from "../consts";
import { Image } from "astro:assets";
import graduationPic from "../assets/graduation_pic.jpg";
---

<AboutLayout
  title="About Me"
  description="CS grad on a deliberate path toward Robotics & ML engineering. Here's where I'm coming from and where I'm headed."
>
  <section class="intro">
    <p>
      Hey — I'm <strong>Gavin Hungaski</strong>, a recent computer science
      graduate based in the US. I got my start building full-stack web
      applications, but my real goal is to work in
      <strong>Robotics and Machine Learning engineering</strong>.
    </p>
    <p>
      Rather than jumping into a course and calling it done, I'm taking a
      project-based approach: build real things, understand them deeply, write
      about what I learn, and document the whole journey publicly. This site is
      that record.
    </p>
  </section>

  <section class="section">
    <h2>My Education</h2>
    <div class="edu-content">
      <Image
        src={graduationPic}
        alt="Gavin Hungaski at graduation"
        class="grad-photo"
      />
      <p>
        I graduated from Kutztown University of Pennsylvania with a B.S. in
        Computer Science in December, 2025.
      </p>
    </div>
  </section>

  <section class="section">
    <h2>Where I'm headed</h2>
    <p>
      My path runs through systems programming (C++, memory management, data
      structures from scratch), then into ML fundamentals (Autograd engine, CNN
      from scratch and a particle filter) then into ROS 2 and real robotics
      middleware (fundamentals bot, lidar, and vision pipeline among others).
      Each project is a deliberate step in that direction — not a checkbox, but
      a real artifact I can point to and explain.
    </p>
  </section>

  <section class="section">
    <h2>Certifications</h2>
    <ul class="cert-list">
      <li>
        <span class="cert-badge">✅</span>
        <div>
          <strong>Full Stack Web Development</strong>
          <a
            class="cert-issuer"
            href="https://www.udemy.com/certificate/UC-d7449106-81ad-4113-8736-0a6b60622995/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span> — Udemy</span></a
          >
        </div>
      </li>
    </ul>
  </section>

  <section class="section">
    <h2>Current Focus</h2>
    <ul class="focus-list">
      <li>
        🔧 <strong>C++ fundamentals</strong> — getting back up to speed with modern
        C++
      </li>
      <li>
        🧠 <strong>Systems programming</strong> — memory allocators, data structures
        from scratch
      </li>
      <li>📡 <strong>Robotics & ML</strong> — next on the roadmap</li>
    </ul>
  </section>

  <section class="section">
    <h2>Skills &amp; Tools</h2>
    <div class="skill-groups">
      <div class="skill-group">
        <h3>Currently learning</h3>
        <div class="tags">
          <span class="tag">C++</span>
          <span class="tag">Systems Programming</span>
          <span class="tag">Memory Management</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>Web background</h3>
        <div class="tags">
          <span class="tag">TypeScript</span>
          <span class="tag">JavaScript</span>
          <span class="tag">React</span>
          <span class="tag">Node.js</span>
          <span class="tag">Astro</span>
          <span class="tag">CSS</span>
          <span class="tag">POSTGRESQL</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Get in touch</h2>
    <p>
      Find me on <a
        href={SOCIAL_LINKS.github}
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      or connect on <a
        href={SOCIAL_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer">LinkedIn</a
      >. I'm always open to talking about systems programming, robotics, or
      anything in between.
    </p>
  </section>
</AboutLayout>

<style>
  .intro p {
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .section {
    margin-top: 2.5em;
  }

  .section h2 {
    font-size: 1.4rem;
    margin-bottom: 0.75em;
    color: rgb(var(--black));
  }
  .edu-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1em;
  }
  .grad-photo {
    width: 100%;
    max-width: 360px;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    object-fit: cover;
  }
  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }
  .cert-list li {
    display: flex;
    align-items: center;
    gap: 0.75em;
    padding: 0.75em 1em;
    background: #fff;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    font-size: 0.95rem;
  }
  .cert-badge {
    font-size: 1.1rem;
  }
  .cert-issuer {
    color: rgb(var(--gray));
    text-decoration: none;
  }
  .focus-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }
  .skill-group h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(var(--gray));
    margin-bottom: 0.5em;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }
  .tag {
    font-size: 0.8rem;
    background: rgb(var(--gray-light));
    color: rgb(var(--gray-dark));
    padding: 0.25em 0.65em;
    border-radius: 4px;
    font-family: monospace;
  }
</style>
