---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const startedProjects = allProjects.filter((p) => p.data.section === 'started');
const roadmapProjects = allProjects.filter((p) => p.data.section === 'roadmap');

const statusLabel: Record<string, string> = {
  'upcoming': '⬜ Upcoming',
  'in-progress': '🟡 In Progress',
  'completed': '✅ Completed',
};

const statusClass: Record<string, string> = {
  'upcoming': 'upcoming',
  'in-progress': 'in-progress',
  'completed': 'completed',
};
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="hero">
    <h1>Hi, I'm <span class="accent">Gavin Hungaski</span></h1>
    <p class="tagline">
      CS grad on a deliberate path from web developer to <strong>Robotics &amp; ML software engineer</strong> —
      documenting every project, cert, and lesson along the way.
    </p>
    <div class="hero-links">
      <a href="/blog" class="btn btn-primary">Read the Blog</a>
      <a href="/about" class="btn btn-secondary">About Me</a>
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">GitHub</a>
    </div>
  </section>

  <hr class="divider" />

  <!-- Where I started -->
  <section class="section">
    <h2>Where I Started</h2>
    <p class="section-subtitle">
      I began my computer science journey with a degree and a dream.
    </p>
    {startedProjects.length > 0 ? (
      <ul class="project-list">
        {startedProjects.map((project) => (
          <li class:list={['project-card', statusClass[project.data.status]]}>
            <div class="project-header">
              <h3 class="project-title">{project.data.title}</h3>
              <span class:list={['status-badge', statusClass[project.data.status]]}>
                {statusLabel[project.data.status]}
              </span>
            </div>
            <p class="project-description">{project.data.description}</p>
            <div class="project-tags">
              {project.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-links">
              {project.data.liveUrl && (
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                  Live Site →
                </a>
              )}
              {project.data.repoUrl && (
                <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                  View on GitHub →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Projects coming soon — stay tuned.</p>
    )}
  </section>

  <hr class="divider" />

  <!-- Project Roadmap -->
  <section class="section">
    <h2>The Path</h2>
    <p class="section-subtitle">
      A project-based roadmap tracking my progression into systems programming, robotics, and ML.
    </p>
    {roadmapProjects.length > 0 ? (
      <ul class="project-list">
        {roadmapProjects.map((project) => (
          <li class:list={['project-card', statusClass[project.data.status]]}>
            <div class="project-header">
              <h3 class="project-title">{project.data.title}</h3>
              <span class:list={['status-badge', statusClass[project.data.status]]}>
                {statusLabel[project.data.status]}
              </span>
            </div>
            <p class="project-description">{project.data.description}</p>
            <div class="project-tags">
              {project.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-links">
              {project.data.liveUrl && (
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                  Live Site →
                </a>
              )}
              {project.data.repoUrl && (
                <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                  View on GitHub →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">Projects coming soon — stay tuned.</p>
    )}
  </section>

  <hr class="divider" />

  <!-- Latest Posts -->
  <section class="section">
    <h2>Latest Posts</h2>
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="post-link">
              <span class="post-title">{post.data.title}</span>
              <span class="post-date">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="all-posts-link">All posts →</a>
    ) : (
      <p class="empty-state">No posts yet — first one coming soon.</p>
    )}
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 3em 0 2em;
    max-width: 640px;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 0.5em;
  }
  .accent {
    color: var(--accent);
  }
  .tagline {
    font-size: 1.1rem;
    color: rgb(var(--gray-dark));
    margin-bottom: 1.5em;
    line-height: 1.6;
  }
  .hero-links {
    display: flex;
    gap: 0.75em;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.55em 1.25em;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border: 2px solid var(--accent);
  }
  .btn-primary:hover {
    background: var(--accent-dark);
    border-color: var(--accent-dark);
    color: var(--bg);
  }
  .btn-secondary {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    background: var(--surface-2);
    color: var(--accent);
  }

  /* Divider */
  .divider {
    margin: 2em 0;
  }

  /* Sections */
  .section {
    padding: 1em 0 2em;
  }
  .section h2 {
    font-size: 1.6rem;
    margin-bottom: 0.25em;
  }
  .section-subtitle {
    color: rgb(var(--gray));
    margin-bottom: 1.5em;
    font-size: 0.92rem;
  }
  .empty-state {
    color: rgb(var(--gray));
    font-style: italic;
  }

  /* Project Cards */
  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .project-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25em 1.5em;
    background: var(--surface);
    box-shadow: none;
    border-left: 4px solid var(--border);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .project-card:hover {
    box-shadow: var(--box-shadow);
  }
  .project-card.in-progress {
    border-left-color: #f59e0b;
  }
  .project-card.completed {
    border-left-color: #10b981;
  }
  .project-card.upcoming {
    border-left-color: var(--border);
  }
  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1em;
    margin-bottom: 0.5em;
    flex-wrap: wrap;
  }
  .project-title {
    margin: 0;
    font-size: 1.05rem;
    color: rgb(var(--black));
  }
  .status-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2em 0.65em;
    border-radius: 20px;
    white-space: nowrap;
    background: var(--surface-2);
    color: rgb(var(--gray-dark));
    border: 1px solid var(--border);
  }
  .status-badge.in-progress {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border-color: rgba(245, 158, 11, 0.3);
  }
  .status-badge.completed {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border-color: rgba(16, 185, 129, 0.3);
  }
  .project-description {
    font-size: 0.88rem;
    color: rgb(var(--gray-dark));
    margin: 0 0 0.75em;
    line-height: 1.55;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    margin-bottom: 0.75em;
  }
  .tag {
    font-size: 0.72rem;
    background: var(--surface-2);
    color: rgb(var(--gray-dark));
    padding: 0.2em 0.6em;
    border-radius: 4px;
    font-family: monospace;
    border: 1px solid var(--border);
  }
  .project-links {
    display: flex;
    gap: 1em;
    flex-wrap: wrap;
  }
  .project-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .project-link:hover {
    text-decoration: underline;
    color: var(--accent-dark);
  }

  /* Post List */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1em;
    display: flex;
    flex-direction: column;
  }
  .post-list li {
    border-bottom: 1px solid var(--border);
  }
  .post-list li:first-child {
    border-top: 1px solid var(--border);
  }
  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
    padding: 0.8em 0.5em;
    text-decoration: none;
    color: rgb(var(--black));
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  .post-link:hover {
    color: var(--accent);
    background: var(--surface-2);
    padding-left: 0.75em;
  }
  .post-title {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .post-date {
    font-size: 0.82rem;
    color: rgb(var(--gray));
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .all-posts-link {
    display: inline-block;
    margin-top: 1em;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .all-posts-link:hover {
    text-decoration: underline;
    color: var(--accent-dark);
  }
</style>
