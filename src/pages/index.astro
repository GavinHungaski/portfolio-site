---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "../components/FormattedDate.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from "../consts";
import profilePic from "../assets/profile.jpeg";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

const startedProjects = allProjects.filter((p) => p.data.section === "started");
const roadmapProjects = allProjects.filter(
  (p) => p.data.section === "roadmap",
);

const statusLabel: Record<string, string> = {
  upcoming: "⬜ Upcoming",
  "in-progress": "🟡 In Progress",
  completed: "✅ Completed",
};
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section
    class="py-12 pb-8 flex items-center justify-between gap-10 flex-wrap max-sm:flex-col-reverse max-sm:items-start max-sm:gap-6"
  >
    <!-- Text -->
    <div class="flex-1 min-w-[260px]">
      <h1 class="text-[clamp(2rem,5vw,3.5rem)] leading-tight mb-2 font-bold">
        Hi, I'm <span class="text-[var(--accent)]">Gavin Hungaski</span>
      </h1>
      <p class="text-lg text-[rgb(var(--gray-dark))] mb-6 leading-relaxed">
        CS grad on a deliberate path from web developer to <strong
          >Robotics &amp; ML software engineer</strong
        > —
        documenting every project, cert, and lesson along the way.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a
          href="/blog"
          class="inline-block px-5 py-2 rounded-md text-sm font-semibold no-underline bg-transparent text-[var(--accent)] border-2 border-[var(--border)] transition-all duration-150 hover:border-[var(--accent)] hover:bg-[var(--surface-2)]"
        >
          Read the Blog
        </a>
        <a
          href="/about"
          class="inline-block px-5 py-2 rounded-md text-sm font-semibold no-underline bg-transparent text-[var(--accent)] border-2 border-[var(--border)] transition-all duration-150 hover:border-[var(--accent)] hover:bg-[var(--surface-2)]"
        >
          About Me
        </a>
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-5 py-2 rounded-md text-sm font-semibold no-underline bg-transparent text-[var(--accent)] border-2 border-[var(--border)] transition-all duration-150 hover:border-[var(--accent)] hover:bg-[var(--surface-2)]"
        >
          GitHub
        </a>
      </div>
    </div>

    <!-- Profile photo -->
    <div class="shrink-0 flex items-center justify-center">
      <Image
        src={profilePic}
        alt="Gavin Hungaski"
        width={220}
        height={220}
        class="w-[220px] h-[220px] max-sm:w-[140px] max-sm:h-[140px] rounded-full object-cover border-2 border-[var(--border)] shadow-[0_4px_20px_rgba(0,0,0,0.15)]"
      />
    </div>
  </section>

  <hr class="my-8 border-[var(--border)]" />

  <!-- ── Where I Started ───────────────────────────────────────── -->
  <section class="py-4 pb-8">
    <h2 class="text-[1.6rem] font-bold mb-1 text-[rgb(var(--black))]">
      Where I Started
    </h2>
    <p class="text-[rgb(var(--gray))] mb-6 text-sm">
      I began my computer science journey with a degree and a dream.
    </p>

    {
      startedProjects.length > 0 ? (
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          {startedProjects.map((project) => (
            <li
              class:list={[
                "border border-[var(--border)] rounded-xl px-6 py-5 bg-[var(--surface)] border-l-4 transition-shadow duration-150 hover:shadow-[var(--box-shadow)]",
                {
                  "border-l-amber-400": project.data.status === "in-progress",
                  "border-l-emerald-500": project.data.status === "completed",
                  "border-l-[var(--border)]": project.data.status === "upcoming",
                },
              ]}
            >
              <!-- Header row -->
              <div class="flex items-start justify-between gap-4 mb-2 flex-wrap">
                <h3 class="m-0 text-base font-semibold text-[rgb(var(--black))]">
                  {project.data.title}
                </h3>
                <span
                  class:list={[
                    "text-xs font-semibold px-2.5 py-0.5 rounded-full whitespace-nowrap border",
                    {
                      "bg-amber-400/15 text-amber-400 border-amber-400/30":
                        project.data.status === "in-progress",
                      "bg-emerald-500/15 text-emerald-500 border-emerald-500/30":
                        project.data.status === "completed",
                      "bg-[var(--surface-2)] text-[rgb(var(--gray-dark))] border-[var(--border)]":
                        project.data.status === "upcoming",
                    },
                  ]}
                >
                  {statusLabel[project.data.status]}
                </span>
              </div>

              <!-- Description -->
              <p class="text-sm text-[rgb(var(--gray-dark))] m-0 mb-3 leading-relaxed">
                {project.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {project.data.tags.map((tag: string) => (
                  <span class="text-xs bg-[var(--surface-2)] text-[rgb(var(--gray-dark))] px-2 py-0.5 rounded font-mono border border-[var(--border)]">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex gap-4 flex-wrap">
                {project.data.liveUrl && (
                  <a
                    href={project.data.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-[var(--accent)] no-underline hover:underline hover:text-[var(--accent-dark)]"
                  >
                    Live Site →
                  </a>
                )}
                {project.data.repoUrl && (
                  <a
                    href={project.data.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-[var(--accent)] no-underline hover:underline hover:text-[var(--accent-dark)]"
                  >
                    View on GitHub →
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-[rgb(var(--gray))] italic">
          Projects coming soon — stay tuned.
        </p>
      )
    }
  </section>

  <hr class="my-8 border-[var(--border)]" />

  <!-- ── The Path (Roadmap) ─────────────────────────────────────── -->
  <section class="py-4 pb-8">
    <h2 class="text-[1.6rem] font-bold mb-1 text-[rgb(var(--black))]">
      The Path
    </h2>
    <p class="text-[rgb(var(--gray))] mb-6 text-sm">
      A project-based roadmap tracking my progression into systems programming,
      robotics, and ML.
    </p>

    {
      roadmapProjects.length > 0 ? (
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          {roadmapProjects.map((project) => (
            <li
              class:list={[
                "border border-[var(--border)] rounded-xl px-6 py-5 bg-[var(--surface)] border-l-4 transition-shadow duration-150 hover:shadow-[var(--box-shadow)]",
                {
                  "border-l-amber-400": project.data.status === "in-progress",
                  "border-l-emerald-500": project.data.status === "completed",
                  "border-l-[var(--border)]": project.data.status === "upcoming",
                },
              ]}
            >
              <!-- Header row -->
              <div class="flex items-start justify-between gap-4 mb-2 flex-wrap">
                <h3 class="m-0 text-base font-semibold text-[rgb(var(--black))]">
                  {project.data.title}
                </h3>
                <span
                  class:list={[
                    "text-xs font-semibold px-2.5 py-0.5 rounded-full whitespace-nowrap border",
                    {
                      "bg-amber-400/15 text-amber-400 border-amber-400/30":
                        project.data.status === "in-progress",
                      "bg-emerald-500/15 text-emerald-500 border-emerald-500/30":
                        project.data.status === "completed",
                      "bg-[var(--surface-2)] text-[rgb(var(--gray-dark))] border-[var(--border)]":
                        project.data.status === "upcoming",
                    },
                  ]}
                >
                  {statusLabel[project.data.status]}
                </span>
              </div>

              <!-- Description -->
              <p class="text-sm text-[rgb(var(--gray-dark))] m-0 mb-3 leading-relaxed">
                {project.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {project.data.tags.map((tag: string) => (
                  <span class="text-xs bg-[var(--surface-2)] text-[rgb(var(--gray-dark))] px-2 py-0.5 rounded font-mono border border-[var(--border)]">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex gap-4 flex-wrap">
                {project.data.liveUrl && (
                  <a
                    href={project.data.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-[var(--accent)] no-underline hover:underline hover:text-[var(--accent-dark)]"
                  >
                    Live Site →
                  </a>
                )}
                {project.data.repoUrl && (
                  <a
                    href={project.data.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-[var(--accent)] no-underline hover:underline hover:text-[var(--accent-dark)]"
                  >
                    View on GitHub →
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-[rgb(var(--gray))] italic">
          Projects coming soon — stay tuned.
        </p>
      )
    }
  </section>

  <hr class="my-8 border-[var(--border)]" />

  <!-- ── Latest Posts ───────────────────────────────────────────── -->
  <section class="py-4 pb-8">
    <h2 class="text-[1.6rem] font-bold mb-4 text-[rgb(var(--black))]">
      Latest Posts
    </h2>

    {
      posts.length > 0 ? (
        <>
          <ul class="list-none p-0 m-0 mb-4 flex flex-col">
            {posts.map((post) => (
              <li class="border-b border-[var(--border)] first:border-t first:border-[var(--border)]">
                <a
                  href={`/blog/${post.id}/`}
                  class="flex justify-between items-baseline gap-4 px-2 py-3 no-underline text-[rgb(var(--black))] rounded transition-colors duration-150 hover:text-[var(--accent)] hover:bg-[var(--surface-2)] hover:pl-3"
                >
                  <span class="font-semibold text-[0.95rem]">
                    {post.data.title}
                  </span>
                  <span class="text-sm text-[rgb(var(--gray))] whitespace-nowrap tabular-nums shrink-0">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <a
            href="/blog"
            class="inline-block text-sm font-semibold text-[var(--accent)] no-underline hover:underline hover:text-[var(--accent-dark)]"
          >
            All posts →
          </a>
        </>
      ) : (
        <p class="text-[rgb(var(--gray))] italic">
          No posts yet — first one coming soon.
        </p>
      )
    }
  </section>
</BaseLayout>
