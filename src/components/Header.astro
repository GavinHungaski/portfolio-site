---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import SocialLinks from "./SocialLinks.astro";
---

<header
  class="sticky top-0 z-50 bg-[var(--surface)] border-b border-[var(--border)] px-6 transition-colors duration-200"
>
  <nav class="flex items-center justify-between gap-4 h-14">
    <!-- Site title -->
    <h2 class="m-0 text-base whitespace-nowrap">
      <a
        href="/"
        class="font-mono font-bold text-base tracking-tight no-underline text-[rgb(var(--black))] hover:text-[var(--accent)] transition-colors duration-150"
      >
        {SITE_TITLE}
      </a>
    </h2>

    <!-- Nav links + social icons -->
    <div class="flex items-center gap-2">
      <div class="flex items-center">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
      </div>
      <span class="text-[rgb(var(--gray))] select-none">|</span>
      <SocialLinks class="header-social hidden sm:flex" />
    </div>

    <!-- Dark / light theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle light/dark theme"
      title="Toggle light/dark theme"
      class="flex items-center justify-center w-[34px] h-[34px] shrink-0 border border-[var(--border)] rounded-md bg-transparent text-[rgb(var(--gray-dark))] cursor-pointer p-0 transition-colors duration-150 hover:text-[var(--accent)] hover:bg-[var(--surface-2)] hover:border-[var(--accent)]"
    >
      <!-- Sun icon (shown in dark mode to switch to light) -->
      <svg
        class="icon-sun"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
      <!-- Moon icon (shown in light mode to switch to dark) -->
      <svg
        class="icon-moon"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </nav>
</header>

<!-- Icon visibility is toggled via CSS based on the data-theme attribute -->
<style>
  :root .icon-sun { display: none; }
  :root .icon-moon { display: block; }
  html[data-theme="dark"] .icon-moon { display: none; }
  html[data-theme="dark"] .icon-sun { display: block; }
</style>

<script is:inline>
  const btn = document.getElementById("theme-toggle");

  function applyTheme(theme) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("theme", theme);
  }

  function getCurrentTheme() {
    return document.documentElement.dataset.theme ?? "light";
  }

  if (btn) {
    btn.addEventListener("click", () => {
      const next = getCurrentTheme() === "dark" ? "light" : "dark";
      applyTheme(next);
    });
  }
</script>
