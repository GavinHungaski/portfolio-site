---
import { AUTHOR_FULL_NAME } from '../consts';
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer>
  <SocialLinks class="footer-social" />
  <p class="copyright">
    &copy; {today.getFullYear()} {AUTHOR_FULL_NAME}. All rights reserved.
  </p>
</footer>

<style>
  footer {
    padding: 2.5em 1em 4em;
    background: var(--surface);
    border-top: 1px solid var(--border);
    color: rgb(var(--gray));
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1em;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .footer-social {
    color: rgb(var(--gray));
    justify-content: center;
  }
  .copyright {
    margin: 0;
    font-size: 0.875em;
  }
</style>
